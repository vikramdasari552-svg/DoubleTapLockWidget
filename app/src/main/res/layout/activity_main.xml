<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <ImageView
            android:layout_width="88dp"
            android:layout_height="88dp"
            android:layout_gravity="center_horizontal"
            android:contentDescription="@string/app_name"
            android:src="@mipmap/ic_launcher" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:text="Double Tap Lock Widget"
            android:textColor="@color/on_surface"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="Transparent home-screen gesture area"
            android:textColor="@color/on_surface"
            android:textSize="15sp" />

        <Button
            android:id="@+id/openAccessibility"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Enable lock and system actions" />

        <Button
            android:id="@+id/cameraPermission"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Allow flashlight control" />

        <Button
            android:id="@+id/openWidgets"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="How to add the widget" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="Tap timing"
            android:textColor="@color/on_surface"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="Maximum gap between taps"
            android:textColor="@color/on_surface"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/tapIntervalValue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/on_surface"
            android:textSize="14sp" />

        <SeekBar
            android:id="@+id/tapInterval"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Wait after the second tap for a possible third tap"
            android:textColor="@color/on_surface"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/doubleDelayValue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/on_surface"
            android:textSize="14sp" />

        <SeekBar
            android:id="@+id/doubleDelay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <CheckBox
            android:id="@+id/enableTripleTap"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="Triple tap toggles flashlight"
            android:textColor="@color/on_surface" />

        <CheckBox
            android:id="@+id/enableHaptic"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Vibrate after a successful action"
            android:textColor="@color/on_surface" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:text="Optional four-tap action"
            android:textColor="@color/on_surface"
            android:textSize="16sp"
            android:textStyle="bold" />

        <Spinner
            android:id="@+id/fourTapAction"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="Gestures\n\n• Double tap: lock screen\n• Triple tap: flashlight on/off\n• Four taps: selected system action\n\nThe widget uses only its own home-screen cells. It does not place an overlay over Recents, the app drawer, shortcuts, or other apps. Arbitrary swipes and two-finger gestures are not available to Android RemoteViews widgets."
            android:textColor="@color/on_surface"
            android:textSize="15sp" />

    </LinearLayout>
</ScrollView>

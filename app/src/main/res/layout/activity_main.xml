<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <ImageView
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:layout_gravity="center_horizontal"
            android:contentDescription="@string/app_name"
            android:src="@mipmap/ic_launcher" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:text="Double Tap Lock Widget"
            android:textColor="@color/on_surface"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="A transparent, resizable widget that locks your Pixel when you double tap its area. It does not place an overlay over Recents, the app drawer, or other apps."
            android:textColor="@color/on_surface"
            android:textSize="16sp" />

        <Button
            android:id="@+id/openAccessibility"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Enable lock service" />

        <Button
            android:id="@+id/openWidgets"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="How to add the widget" />

        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:textColor="@color/on_surface"
            android:textSize="15sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Setup\n\n1. Enable the lock service.\n2. Long-press an empty part of your home screen.\n3. Choose Widgets.\n4. Find Double Tap Lock Widget.\n5. Add it and resize it over the empty area.\n6. Double tap inside that widget area to lock.\n\nThe widget is transparent after placement."
            android:textColor="@color/on_surface"
            android:textSize="16sp" />

    </LinearLayout>
</ScrollView>
